from server import make_server
from server import parse_port
from server import run_server
import c "stdio.h" as stdio
import c "unistd.h" as unistd


def main() -> i32:
    port = parse_port()
    server = make_server(port)
    if server < 0:
        return 1

    stdio.printf("dudu-webserver listening on http://127.0.0.1:%d\n", port)
    stdio.printf("press Ctrl-C to stop\n")
    run_server(server)
    unistd.close(server)
    return 0
